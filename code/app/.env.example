# Copy to `.env` in this folder (`app/.env`). Do not commit real secrets.

# groq | openrouter | ollama
LLM_BACKEND=openrouter

# Groq (when LLM_BACKEND=groq)
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b

# OpenRouter (when LLM_BACKEND=openrouter) — https://openrouter.ai/keys
OPENROUTER_API_KEY=<your_openrouter_api_key>
OPENROUTER_MODEL=qwen/qwen3.5-397b-a17b
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=http://localhost
# OPENROUTER_APP_TITLE=EGE RAG PoC
# OPENROUTER_TIMEOUT=600
# OPENROUTER_MAX_RETRIES=3

# Ollama (when LLM_BACKEND=ollama)
# Local daemon (default). Do not point at https://ollama.com unless you use Ollama Cloud on purpose.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_TIMEOUT=600
# Retries on HTTP 502/503/504 (cloud hiccups or transient errors)
OLLAMA_MAX_RETRIES=3

# Conspect: extra LLM verify+repair pass. Default: on for groq, off for ollama.
# CONSPECT_VERIFY=true
# Second pass: arithmetic check for practice/example answers (default: same as CONSPECT_VERIFY)
# CONSPECT_MATH_VERIFY=false

# FIPI task bank JSON (default: ../fipi_parsed_katex.json relative to app package parent)
# FIPI_PARSED_JSON=

# Embeddings: local (sentence-transformers) or openrouter
# EMBED_BACKEND=local
# EMBED_MODEL=BAAI/bge-m3
#
# OpenRouter embeddings (OPENROUTER_API_KEY or optional OPENROUTER_EMBED_API_KEY)
EMBED_BACKEND=openrouter
EMBED_MODEL=qwen/qwen3-embedding-8b
# OPENROUTER_EMBED_BATCH=64
# OPENROUTER_EMBED_API_KEY=<your_openrouter_api_key>
# If you see "No successful provider responses": set provider order (slugs from OpenRouter docs)
# OPENROUTER_EMBED_PROVIDER_ORDER=openai
# Or full JSON: OPENROUTER_EMBED_PROVIDER_JSON={"order":["openai"],"allow_fallbacks":true}
# Override fallback models (default: qwen/qwen3-embedding-8b, openai/text-embedding-3-large)
# OPENROUTER_EMBED_MODEL_FALLBACKS=
# OPENROUTER_CONNECT_TIMEOUT=30

# Qdrant: URL and collection name
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ege_rag_atoms

# Retrieval judge model override (used by app/rag/eval/judge_retrieval.py)
# If set, overrides the backend's default model only for judge/eval calls.
# Example (openrouter): JUDGE_MODEL=qwen/qwen3-32b
JUDGE_MODEL=minimax/minimax-m2.7

# Conspect MCP server/client settings
# For docker-compose, keep CONSPECT_MCP_URL pointed at the mcp service.
CONSPECT_MCP_TRANSPORT=streamable-http
CONSPECT_MCP_HOST=0.0.0.0
CONSPECT_MCP_PORT=8001
CONSPECT_MCP_PATH=/mcp
CONSPECT_MCP_URL=http://mcp:8001/mcp
# CONSPECT_MCP_PROFILES_DIR=

# LangSmith settings
LANGSMITH_API_KEY=<your_langsmith_api_key>
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ege-rag-workspace

HF_TOKEN=<your_huggingface_token>

# Platform integration
# Where eval-worker and conspect-worker POST callbacks.
# Locally: http://127.0.0.1:8100 (ege-admin).  In compose: http://ege-admin:8100.
PLATFORM_BASE_URL=http://127.0.0.1:8100
# Optional: if set, the /jobs endpoint requires this token. Leave empty to accept any Bearer.
PLATFORM_AUTH_TOKEN=

# Postgres connection (raw asyncpg DSN — used by workers and ege-admin).
DATABASE_URL=postgresql+asyncpg://ege:ege@127.0.0.1:5432/ege_generator

# Kafka broker list (comma-separated).
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
